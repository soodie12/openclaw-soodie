        "output": 0,
        "cacheRead": 0,
        "cacheWrite": 0
      }
    }
  ],
  "providers": {
    "groq": {
      "apiKey": "${GROQ_API_KEY}"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy" : "allowlist",
      "allowFrom": ["tg:7009229473"]
    }
  }
}
